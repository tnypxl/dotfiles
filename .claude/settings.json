{
  "env": {
    "DISABLE_AUTOUPDATER": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [],
    "deny": [],
    "ask": [],
    "defaultMode": "default"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -f ./session.yml && jq -n --rawfile c ./session.yml '{systemMessage: \"\\ud83d\\udcc4 session.yml loaded\", hookSpecificOutput: {hookEventName: \"UserPromptSubmit\", additionalContext: (\"<session.yml>\\n\" + $c + \"</session.yml>\")}}'; exit 0"
          }
        ]
      }
    ]
  },
  "workflowKeywordTriggerEnabled": false,
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "impeccable": {
      "source": {
        "source": "github",
        "repo": "pbakaus/impeccable"
      }
    }
  },
  "effortLevel": "medium",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "editorMode": "normal",
  "verbose": true,
  "preferredNotifChannel": "ghostty",
  "autoCompactEnabled": true,
  "switchModelsOnFlag": true,
  "showTurnDuration": true,
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "useAutoModeDuringPlan": false,
  "model": "sonnet"
}
